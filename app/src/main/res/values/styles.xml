<resources>

    <!-- Main App Theme with Material 3 overlay -->
    <style name="AppTheme" parent="Theme.ContactsPlus.Material3">
        <item name="android:windowBackground">@color/md_theme_background</item>
    </style>

    <style name="AppTheme.Base" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/md_theme_background</item>
        <item name="android:colorBackground">@color/md_theme_background</item>
    </style>

    <style name="FossifyTheme" parent="AppTheme" />

    <style name="roundedImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Settings Styles -->
    <style name="SettingsSwitchStyle">
        <item name="android:background">@null</item>
        <item name="android:clickable">false</item>
        <item name="android:textSize">@dimen/normal_text_size</item>
    </style>

    <style name="SettingsTextLabelStyle">
        <item name="android:textSize">@dimen/normal_text_size</item>
    </style>

    <style name="SettingsTextValueStyle">
        <item name="android:alpha">0.6</item>
        <item name="android:textFontWeight">300</item>
        <item name="android:textSize">@dimen/normal_text_size</item>
    </style>

    <style name="SettingsHolderSwitchStyle">
        <item name="android:paddingStart">@dimen/settings_label_start_margin</item>
        <item name="android:paddingTop">@dimen/medium_margin</item>
        <item name="android:paddingEnd">@dimen/settings_label_start_margin</item>
        <item name="android:paddingBottom">@dimen/medium_margin</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <style name="SettingsHolderTextViewStyle">
        <item name="android:paddingStart">@dimen/settings_label_start_margin</item>
        <item name="android:paddingTop">@dimen/activity_margin</item>
        <item name="android:paddingEnd">@dimen/settings_label_start_margin</item>
        <item name="android:paddingBottom">@dimen/activity_margin</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <style name="SettingsHolderTextViewOneLinerStyle" parent="@style/SettingsHolderTextViewStyle">
        <item name="android:paddingTop">@dimen/bigger_margin</item>
        <item name="android:paddingBottom">@dimen/bigger_margin</item>
    </style>

    <style name="SettingsSectionLabelStyle">
        <item name="android:layout_marginStart">@dimen/settings_label_start_margin</item>
        <item name="android:textColor">@color/md_theme_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="UnclickableEditText">
        <item name="android:clickable">false</item>
        <item name="android:focusable">false</item>
        <item name="android:inputType">textNoSuggestions|textMultiLine</item>
    </style>

    <!-- Contact list item styles -->
    <style name="ContactListItem">
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <!-- Large avatar style -->
    <style name="LargeAvatarStyle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Contact detail section header -->
    <style name="ContactSectionHeader">
        <item name="android:textAppearance">@style/TextAppearance.ContactsPlus.LabelMedium</item>
        <item name="android:textColor">@color/md_theme_primary</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- Social link chip style -->
    <style name="SocialLinkChip" parent="Widget.Material3.Chip.Assist">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipMinHeight">36dp</item>
        <item name="chipStartPadding">8dp</item>
        <item name="chipEndPadding">12dp</item>
        <item name="chipIconSize">20dp</item>
        <item name="android:textAppearance">@style/TextAppearance.ContactsPlus.LabelLarge</item>
    </style>

    <style name="SplashTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/md_theme_background</item>
    </style>

    <style name="TranslucentTheme" parent="AppTheme">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

</resources>
