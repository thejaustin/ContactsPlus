<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="@dimen/spacing_lg"
    app:cardBackgroundColor="@color/md_theme_surfaceContainerHigh"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xl">

        <!-- Social Platform Info -->
        <ImageView
            android:id="@+id/card_platform_icon"
            android:layout_width="@dimen/avatar_size_xl"
            android:layout_height="@dimen/avatar_size_xl"
            android:padding="@dimen/spacing_md"
            tools:src="@drawable/ic_instagram" />

        <TextView
            android:id="@+id/card_social_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="@color/md_theme_onSurface"
            tools:text="John Doe" />

        <TextView
            android:id="@+id/card_social_handle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/md_theme_onSurfaceVariant"
            tools:text="@johndoe" />

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/divider_thickness"
            android:layout_marginVertical="@dimen/spacing_xl"
            android:background="@color/md_theme_outlineVariant" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/matches_with"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="@color/md_theme_primary" />

        <!-- Suggested Device Contact -->
        <RelativeLayout
            android:id="@+id/card_suggested_contact_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center">

            <ImageView
                android:id="@+id/card_contact_image"
                android:layout_width="@dimen/avatar_size_lg"
                android:layout_height="@dimen/avatar_size_lg"
                android:layout_centerVertical="true"
                android:scaleType="centerCrop"
                tools:src="@drawable/ic_person_vector" />

            <TextView
                android:id="@+id/card_contact_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_toEndOf="@+id/card_contact_image"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textColor="@color/md_theme_onSurface"
                tools:text="John Smith" />

        </RelativeLayout>

        <TextView
            android:id="@+id/card_no_suggestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/manual_search"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
